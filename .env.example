# WebSocket server for Foundry module connection (game state)
WS_PORT=3300
WS_AUTH_TOKEN=your-ws-auth-token
# Dedicated WebSocket port for video traffic (default: WS_PORT + 1)
# VIDEO_WS_PORT=3301

# MCP server
MCP_PORT=3002
MCP_AUTH_TOKEN=your-mcp-token
# Optional: Unix Domain Socket path (Linux only, overrides MCP_PORT)
MCP_SOCKET_PATH=

# Video capture output directory
VIDEO_DIR=./data/video
